{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "onboardingCompleted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["username", "onboardingCompleted", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A daily task for the user (lesson or reading)",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["lesson", "book"] },
        "date": { "type": "string", "description": "YYYY-MM-DD format" },
        "completed": { "type": "boolean" },
        "pagesToRead": { "type": "number" },
        "bookName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "type", "date", "completed", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "users/{userId}/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "User's daily tasks"
    }
  }
}
